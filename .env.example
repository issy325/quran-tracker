# Copy this file to .env and fill in your values.
# .env is never pushed to GitHub — keep your secrets safe.

# Supabase connection string (get this from Supabase > Project Settings > Database > URI)
# Make sure to use the "Transaction" pooler URL (port 6543) for Vercel serverless
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# A secret key used to protect the /api/sync endpoint.
# Make it long and random — e.g. a UUID. Keep this private.
SYNC_API_KEY=replace-with-a-long-random-secret
